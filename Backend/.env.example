# Application Settings
APP_NAME="Gemini Startup Book RAG"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Security
SECRET_KEY="your-secret-key-here-change-in-production-must-be-at-least_32_chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Gemini API
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Supabase Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# OAuth Configuration
# The URL where users will be redirected after OAuth authentication
OAUTH_REDIRECT_URL="http://localhost:8000/api/v1/auth/google/callback"
# Optional: Google OAuth Client ID (if needed for mobile/SPA flows)
OAUTH_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY="./data/chroma_db"
CHROMA_COLLECTION_NAME="startup_books"

# PDF Storage
PDF_STORAGE_PATH="./data"
ALLOWED_EXTENSIONS="pdf,epub,txt,docx,mobi,azw,azw3"
MAX_FILE_SIZE_MB=50

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
TEMPERATURE=0.7
MAX_TOKENS=2048

# CORS Settings
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="./logs/app.log"
